// Checked-in fallback for CI/Xcode Cloud.
// Local and CI builds may overwrite this file via: `flutter build ios --config-only`.
//
// This file must exist at checkout, otherwise Xcode fails early when parsing
// ios/Flutter/Release.xcconfig (#include "Generated.xcconfig").
FLUTTER_APPLICATION_PATH=$(SRCROOT)/..

// Xcode Cloud scripts install Flutter under repo root: <repo>/flutter
FLUTTER_ROOT=$(SRCROOT)/../flutter

COCOAPODS_PARALLEL_CODE_SIGN=true
FLUTTER_TARGET=lib/main.dart
FLUTTER_BUILD_DIR=build

// These values are usually set from pubspec by Flutter tooling.
FLUTTER_BUILD_NAME=1.0.1
FLUTTER_BUILD_NUMBER=1

EXCLUDED_ARCHS[sdk=iphonesimulator*]=i386
EXCLUDED_ARCHS[sdk=iphoneos*]=armv7

DART_OBFUSCATION=false
TRACK_WIDGET_CREATION=true
TREE_SHAKE_ICONS=false
PACKAGE_CONFIG=.dart_tool/package_config.json
