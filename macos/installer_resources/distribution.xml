<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="1">
    <title>T2DECODE</title>
    <options customize="never" require-scripts="false"/>
    
    <welcome file="welcome.html"/>
    <readme file="readme.html"/>
    <license file="license.txt"/>
    <conclusion file="conclusion.html"/>
    
    <background file="background.png" alignment="bottomleft" scaling="proportional"/>
    
    <choices-outline>
        <line choice="default"/>
    </choices-outline>
    
    <choice id="default" visible="true" title="T2DECODE Application">
        <pkg-ref id="org.tutodecode.macos"/>
    </choice>
    
    <pkg-ref id="org.tutodecode.macos" version="1.0.2" onConclusion="none">T2DECODE_Component.pkg</pkg-ref>
</installer-gui-script>
