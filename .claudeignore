# --- DOSSIERS GÉNÉRÉS (Les plus lourds) ---
build/
.dart_tool/
.git/
.idea/
.vscode/
bin/
obj/

# --- PLATEFORMES NATIVES (Beaucoup de bruit, peu d'intérêt) ---
# Sauf si tu travailles spécifiquement sur le code natif (Java/Swift/C++)
android/
ios/
linux/
macos/
windows/
web/

# --- DÉPENDANCES & CACHE ---
.packages
.pub-cache/
.pub/
package_config.json
pubspec.lock
# On ignore le lock car il est énorme et Claude connaît déjà tes libs via pubspec.yaml

# --- ASSETS LOURDS (Images, Polices, Vidéos) ---
assets/
images/
fonts/
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.ico
*.mp4
*.wav
*.mp3

# --- FICHIERS SYSTÈME & LOGS ---
*.log
*.lock
.DS_Store
Thumbs.db
temp/
tmp/

# --- PYTHON (Si tu as des scripts pour Ghost AI / Ollama) ---
__pycache__/
*.pyc
venv/
.venv/
env/
.env

# --- EXCEL (Fichiers temporaires) ---
~$*
